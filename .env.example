# JWT Authentication (REQUIRED - generate with: openssl rand -base64 64)
JWT_SECRET=

# Admin user password (REQUIRED for first startup - seeded into MongoDB)
ADMIN_PASSWORD=

# CORS allowed origins (comma-separated, no trailing slash)
CORS_ALLOWED_ORIGINS=http://localhost:80,http://localhost:4321

# Neo4j credentials (REQUIRED - no default, startup fails if missing)
NEO4J_URI=bolt://localhost:7687
NEO4J_PASSWORD=

# MongoDB credentials
MONGO_USER=
MONGO_PASSWORD=

# Synology NAS API (optional - leave empty to disable)
SYNOLOGY_HOST=
SYNOLOGY_USERNAME=
SYNOLOGY_PASSWORD=
SYNOLOGY_PATH_PREFIX=/volume1
SYNOLOGY_LOCAL_MOUNT_PREFIX=/mnt/nas
SYNOLOGY_SEARCH_EXTENSIONS=pst,ost
SYNOLOGY_BATCH_SIZE=100
