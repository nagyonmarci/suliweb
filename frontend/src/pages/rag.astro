---
import Layout from '../layouts/Layout.astro';
import RagSearch from '../components/RagSearch.tsx';
import RagChat from '../components/RagChat.tsx';
---

<Layout title="RAG – Levelezési asszisztens" activePage="/rag">
  <!-- Tab nav -->
  <div class="mb-6">
    <div id="tab-bar" class="flex gap-1 p-1 bg-gray-100 rounded-xl w-fit">
      <button
        id="tab-chat"
        class="tab-btn hidden px-5 py-2 text-sm font-medium rounded-lg transition-all"
      >💬 Chat</button>
      <button
        id="tab-search"
        class="tab-btn px-5 py-2 text-sm font-medium rounded-lg transition-all text-gray-600 hover:text-gray-900"
      >🔍 Szemantikus keresés</button>
      <button
        id="tab-manage"
        class="tab-btn px-5 py-2 text-sm font-medium rounded-lg transition-all text-gray-600 hover:text-gray-900"
      >⚙️ Kezelés</button>
    </div>
  </div>

  <!-- Tab panels -->
  <div id="panel-chat" class="hidden">
    <RagChat client:load />
  </div>

  <div id="panel-search" class="hidden">
    <RagSearch client:load mode="search" />
  </div>

  <div id="panel-manage" class="hidden">
    <RagSearch client:load mode="manage" />
  </div>
</Layout>

<script>
  const VALID_TABS = ['chat', 'search', 'manage'];

  function switchTab(tab: string) {
    VALID_TABS.forEach(p => {
      const panel = document.getElementById('panel-' + p);
      const btn   = document.getElementById('tab-' + p);
      if (!panel || !btn) return;
      if (p === tab) {
        panel.classList.remove('hidden');
        btn.classList.add('bg-white', 'shadow', 'text-blue-700');
        btn.classList.remove('text-gray-600', 'hover:text-gray-900');
      } else {
        panel.classList.add('hidden');
        btn.classList.remove('bg-white', 'shadow', 'text-blue-700');
        btn.classList.add('text-gray-600', 'hover:text-gray-900');
      }
    });
  }

  function activateFromHash(hasChat: boolean) {
    const hash = window.location.hash.replace('#', '');
    const desired = VALID_TABS.includes(hash) ? hash : (hasChat ? 'chat' : 'search');
    // Don't allow chat tab if no permission
    switchTab(desired === 'chat' && !hasChat ? 'search' : desired);
  }

  (async () => {
    // Check RAG_CHAT authority
    let hasChat = false;
    try {
      const token = localStorage.getItem('accessToken');
      if (token) {
        const res = await fetch('/api/auth/me', { headers: { 'Authorization': `Bearer ${token}` } });
        if (res.ok) {
          const user = await res.json();
          hasChat = Array.isArray(user.authorities) && user.authorities.includes('RAG_CHAT');
        }
      }
    } catch { /* silently fail */ }

    const chatBtn = document.getElementById('tab-chat');
    if (hasChat && chatBtn) {
      chatBtn.classList.remove('hidden');
    }

    activateFromHash(hasChat);

    document.querySelectorAll('.tab-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = btn.id.replace('tab-', '');
        if (id === 'chat' && !hasChat) return;
        history.pushState(null, '', '#' + id);
        switchTab(id);
      });
    });

    window.addEventListener('popstate', () => activateFromHash(hasChat));
  })();
</script>
