---
import '../styles/global.css';

interface Props {
  title: string;
  activePage?: string;
}
const { title, activePage = '' } = Astro.props;

const navItems = [
  { href: '/', label: 'Dashboard', icon: 'home' },
  { href: '/emails', label: 'E-mailek', icon: 'mail' },
  { href: '/rag', label: 'RAG Keresés', icon: 'search' },
  { href: '/files', label: 'PST fájlok', icon: 'folder' },
  { href: '/attachments', label: 'Csatolmányok', icon: 'paperclip' },
  { href: '/pipeline', label: 'Pipeline', icon: 'pipeline' },
  { href: '/processing', label: 'Feldolgozás', icon: 'cpu' },
  { href: '/synology', label: 'Synology', icon: 'server' },
  { href: '/ediscovery', label: 'e-Discovery', icon: 'ediscovery' },
  { href: '/knowledge-graph', label: 'Knowledge Graph', icon: 'kg' },
  { href: '/logs', label: 'Logok', icon: 'logs' },
  { href: '/users', label: 'Felhasználók', icon: 'users' },
  { href: '/settings', label: 'Beállítások', icon: 'settings' },
];
---

<!doctype html>
<html lang="hu">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} - SuliWeb</title>
  </head>
  <body class="bg-gray-50 text-gray-900 min-h-screen">
    <!-- Mobile header -->
    <header class="lg:hidden bg-gray-900 text-white flex items-center justify-between px-4 py-3 sticky top-0 z-40">
      <div>
        <h1 class="text-lg font-bold tracking-tight">SuliWeb</h1>
      </div>
      <button id="menu-toggle" class="p-2 rounded-lg hover:bg-gray-800 transition-colors" aria-label="Menü">
        <svg id="menu-icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="menu-icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </header>

    <!-- Overlay -->
    <div id="sidebar-overlay" class="fixed inset-0 bg-black/50 z-40 hidden lg:hidden"></div>

    <div class="flex">
      <!-- Sidebar -->
      <aside id="sidebar" class="fixed lg:sticky top-0 left-0 z-50 w-64 bg-gray-900 text-white h-screen flex flex-col -translate-x-full lg:translate-x-0 transition-transform duration-200 ease-in-out">
        <div class="p-6 border-b border-gray-700 hidden lg:block">
          <h1 class="text-xl font-bold tracking-tight">SuliWeb</h1>
          <p class="text-xs text-gray-400 mt-1">PST Processor</p>
        </div>
        <div class="p-6 border-b border-gray-700 lg:hidden">
          <p class="text-xs text-gray-400">PST Processor</p>
        </div>
        <nav class="flex-1 p-4 space-y-1 overflow-y-auto">
          {navItems.map(item => (
            <a
              href={item.href}
              class:list={[
                'flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors',
                activePage === item.href
                  ? 'bg-blue-600 text-white'
                  : 'text-gray-300 hover:bg-gray-800 hover:text-white'
              ]}
            >
              <span class="w-5 h-5 flex items-center justify-center text-xs">
                {item.icon === 'home' && '⌂'}
                {item.icon === 'mail' && '✉'}
                {item.icon === 'search' && '🔍'}
                {item.icon === 'folder' && '📁'}
                {item.icon === 'paperclip' && '📎'}
                {item.icon === 'pipeline' && '▶'}
                {item.icon === 'cpu' && '⚙'}
                {item.icon === 'server' && '🖥'}
                {item.icon === 'ediscovery' && '⚖'}
                {item.icon === 'kg' && '🕸'}
                {item.icon === 'logs' && '📋'}
                {item.icon === 'users' && '👥'}
                {item.icon === 'settings' && '⚙'}
              </span>
              {item.label}
            </a>
          ))}
        </nav>

        <!-- User info at bottom of sidebar -->
        <div class="p-4 border-t border-gray-700">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2 min-w-0">
              <span class="w-8 h-8 bg-blue-600 rounded-full flex items-center justify-center text-sm font-medium shrink-0" id="user-avatar">?</span>
              <span class="text-sm text-gray-300 truncate" id="user-display-name">...</span>
            </div>
            <button
              id="logout-btn"
              class="text-gray-400 hover:text-white transition-colors p-1 shrink-0"
              title="Kijelentkezés"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
              </svg>
            </button>
          </div>
        </div>
      </aside>

      <!-- Main content -->
      <main class="flex-1 min-w-0">
        <header class="bg-white border-b border-gray-200 px-4 sm:px-8 py-4">
          <h2 class="text-lg font-semibold text-gray-800">{title}</h2>
        </header>
        <div class="p-4 sm:p-8">
          <slot />
        </div>
      </main>
    </div>

    <script>
      // Auth check
      if (!localStorage.getItem('accessToken')) {
        window.location.href = '/login';
      }

      // Load user info
      (async () => {
        try {
          const token = localStorage.getItem('accessToken');
          if (!token) return;

          const res = await fetch('/api/auth/me', {
            headers: { 'Authorization': `Bearer ${token}` },
          });

          if (res.ok) {
            const user = await res.json();
            const avatar = document.getElementById('user-avatar');
            const displayName = document.getElementById('user-display-name');
            if (avatar && user.username) {
              avatar.textContent = user.username.charAt(0).toUpperCase();
            }
            if (displayName && user.username) {
              displayName.textContent = user.username;
            }
          }
        } catch {
          // Silently fail - user info is non-critical
        }
      })();

      // Sidebar toggle
      const toggle = document.getElementById('menu-toggle');
      const sidebar = document.getElementById('sidebar');
      const overlay = document.getElementById('sidebar-overlay');
      const iconOpen = document.getElementById('menu-icon-open');
      const iconClose = document.getElementById('menu-icon-close');

      function openMenu() {
        sidebar?.classList.remove('-translate-x-full');
        overlay?.classList.remove('hidden');
        iconOpen?.classList.add('hidden');
        iconClose?.classList.remove('hidden');
      }

      function closeMenu() {
        sidebar?.classList.add('-translate-x-full');
        overlay?.classList.add('hidden');
        iconOpen?.classList.remove('hidden');
        iconClose?.classList.add('hidden');
      }

      toggle?.addEventListener('click', () => {
        if (sidebar?.classList.contains('-translate-x-full')) {
          openMenu();
        } else {
          closeMenu();
        }
      });

      overlay?.addEventListener('click', closeMenu);

      // Logout
      document.getElementById('logout-btn')?.addEventListener('click', () => {
        localStorage.removeItem('accessToken');
        localStorage.removeItem('refreshToken');
        window.location.href = '/login';
      });

      // ---- Antigravity Easter Egg ----
      (() => {
        const TRIGGER = 'antigravity';
        let keyBuffer = '';
        let active = false;
        let animFrame: number | null = null;
        let bodies: {
          el: HTMLElement;
          origStyle: string;
          x: number; y: number;
          vx: number; vy: number;
          w: number; h: number;
          angle: number; av: number;
        }[] = [];

        const GRAVITY = 0.5;
        const DAMPING = 0.65;
        const FRICTION = 0.88;

        function activate() {
          if (active) return;
          active = true;

          // Banner
          const banner = document.createElement('div');
          banner.id = 'ag-banner';
          Object.assign(banner.style, {
            position: 'fixed', bottom: '16px', left: '50%',
            transform: 'translateX(-50%)', zIndex: '9999',
            background: 'rgba(17,24,39,0.92)', color: '#fff',
            padding: '8px 20px', borderRadius: '999px',
            fontSize: '13px', pointerEvents: 'none',
            backdropFilter: 'blur(6px)',
            boxShadow: '0 4px 24px rgba(0,0,0,0.4)',
            transition: 'opacity 0.4s',
          });
          banner.textContent = '🌌 Antigravitáció aktív — nyomj ESC-et a visszaállításhoz';
          document.body.appendChild(banner);

          // Collect elements to animate
          const selectors = [
            'main header', 'main .p-4 > *', 'main .p-8 > *',
            'aside nav a', 'aside .p-6', 'aside .p-4',
            'header.lg\\:hidden',
          ];
          const seen = new Set<Element>();
          const els: HTMLElement[] = [];
          selectors.forEach(sel => {
            document.querySelectorAll<HTMLElement>(sel).forEach(el => {
              if (!seen.has(el) && el.offsetParent !== null) {
                seen.add(el);
                els.push(el);
              }
            });
          });

          // Snapshot positions, then go fixed
          bodies = els.map(el => {
            const rect = el.getBoundingClientRect();
            const origStyle = el.getAttribute('style') || '';
            const angle = (Math.random() - 0.5) * 0.3;
            const vx = (Math.random() - 0.5) * 4;
            const vy = -(Math.random() * 6 + 2);
            Object.assign(el.style, {
              position: 'fixed',
              left: rect.left + 'px',
              top: rect.top + 'px',
              width: rect.width + 'px',
              margin: '0',
              zIndex: '8000',
              transition: 'none',
              transformOrigin: 'center center',
            });
            return { el, origStyle, x: rect.left, y: rect.top, vx, vy, w: rect.width, h: rect.height, angle, av: (Math.random() - 0.5) * 0.05 };
          });

          // eslint-disable-next-line @typescript-eslint/no-unused-vars
          const floor = window.innerHeight;

          function step() {
            const W = window.innerWidth;
            const H = window.innerHeight;
            bodies.forEach(b => {
              b.vy += GRAVITY;
              b.x += b.vx;
              b.y += b.vy;
              b.angle += b.av;

              // Floor bounce
              if (b.y + b.h >= H) {
                b.y = H - b.h;
                b.vy *= -DAMPING;
                b.vx *= FRICTION;
                b.av *= FRICTION;
                if (Math.abs(b.vy) < 1) b.vy = 0;
              }
              // Wall bounce
              if (b.x < 0) { b.x = 0; b.vx *= -DAMPING; }
              if (b.x + b.w > W) { b.x = W - b.w; b.vx *= -DAMPING; }

              b.el.style.left = b.x + 'px';
              b.el.style.top = b.y + 'px';
              b.el.style.transform = `rotate(${b.angle}rad)`;
            });
            animFrame = requestAnimationFrame(step);
          }

          animFrame = requestAnimationFrame(step);
        }

        function deactivate() {
          if (!active) return;
          active = false;
          if (animFrame !== null) { cancelAnimationFrame(animFrame); animFrame = null; }
          bodies.forEach(b => {
            b.el.setAttribute('style', b.origStyle);
          });
          bodies = [];
          document.getElementById('ag-banner')?.remove();
        }

        document.addEventListener('keydown', (e: KeyboardEvent) => {
          if (e.key === 'Escape') { deactivate(); keyBuffer = ''; return; }
          if (e.key.length === 1) {
            keyBuffer += e.key.toLowerCase();
            if (keyBuffer.length > TRIGGER.length + 5) keyBuffer = keyBuffer.slice(-TRIGGER.length - 5);
            if (keyBuffer.includes(TRIGGER)) { activate(); keyBuffer = ''; }
          }
        });
      })();
      // ---- End Antigravity ----
    </script>
  </body>
</html>
